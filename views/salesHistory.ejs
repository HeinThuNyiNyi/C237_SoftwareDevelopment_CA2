<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sales History - CampusCycle</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('partials/navbar') %>

<section class="hero">
    <h1>Sales History</h1>
    <p>Your listings and everything you've sold.</p>
</section>

<% if ((errors && errors.length > 0) || (success && success.length > 0)) { %>
    <div class="admin-section" style="padding-bottom:0;">
        <%- include('partials/flashMessages', {
            successMessages: success,
            errorMessages: errors
        }) %>
    </div>
<% } %>

<!-- Status filter tabs -->
<div class="admin-section" style="ppadding-top:0; display:flex; gap:8px;">
    <a href="/sales-history?status=all" class="<%= selectedStatus === 'all' ? 'btn-primary' : 'btn-outline' %>">All</a>
    <a href="/sales-history?status=pending" class="<%= selectedStatus === 'pending' ? 'btn-primary' : 'btn-outline' %>">Pending Approval</a>
    <a href="/sales-history?status=selling" class="<%= selectedStatus === 'selling' ? 'btn-primary' : 'btn-outline' %>">Selling</a>
    <a href="/sales-history?status=reserved" class="<%= selectedStatus === 'reserved' ? 'btn-primary' : 'btn-outline' %>">Reserved</a>
</div>

<div class="admin-section">
    <h2>Your Listings</h2>

    <% if (listings.length === 0) { %>
        <p>No listings here yet.</p>
    <% } %>

    <% listings.forEach(function(listing) { %>
        <div class="review-card">
            <div class="review-thumb">
                <% if (listing.image) { %>
                    <img src="/images/products/<%= listing.image %>" alt="<%= listing.name %>" style="width:100%; height:100%; object-fit:cover; border-radius:12px;">
                <% } else { %>
                    &#128230;
                <% } %>
            </div>
            <div class="review-body">
                <h4><%= listing.name %></h4>
                <p class="review-meta">Category: <%= listing.categoryName || 'Other' %> &middot; $<%= Number(listing.price).toFixed(2) %></p>
                <p class="review-meta">Quantity: <%= listing.quantity %></p>
                <p class="review-meta">Listed: <%= new Date(listing.created_at).toLocaleDateString() %></p>
                <% if (listing.status === 'rejected' && listing.rejection_reason) { %>
                    <p class="review-meta">Rejection reason: <%= listing.rejection_reason %></p>
                <% } %>
            </div>
            <div class="review-actions review-actions-compact">
                <span class="status-badge status-<%= listing.status %>" style="position:static; display:inline-block; width:fit-content;"><%= listing.status.replace('_', ' ') %></span>
                <% if (listing.status === 'selling') { %>
                    <div class="review-actions-row">
                        <a href="/products/<%= listing.id %>/edit" class="btn-outline">Edit</a>
                        <form action="/products/<%= listing.id %>/delete" method="POST" onsubmit="return confirm('Delete this listing? This cannot be undone.');">
                            <button type="submit" class="btn-danger">Delete</button>
                        </form>
                    </div>
                <% } %>
            </div>
        </div>
    <% }); %>
</div>

<div class="admin-section">
    <h2>Completed Sales</h2>

    <% if (sales.length === 0) { %>
        <p>You haven't completed any sales yet.</p>
    <% } %>

    <% sales.forEach(function(sale) { %>
        <div class="review-card">
            <div class="review-thumb">
                <% if (sale.productImage) { %>
                    <img src="/images/products/<%= sale.productImage %>" alt="<%= sale.productName %>" style="width:100%; height:100%; object-fit:cover; border-radius:12px;">
                <% } else { %>
                    &#128230;
                <% } %>
            </div>
            <div class="review-body">
                <h4><%= sale.productName %></h4>
                <p class="review-meta">Buyer: <%= sale.buyerName %></p>
                <p class="review-meta">Sale price: $<%= Number(sale.price).toFixed(2) %></p>
                <p class="review-meta">Sold: <%= new Date(sale.purchased_at).toLocaleDateString() %></p>
            </div>
            <div class="review-actions">
                <span class="status-badge status-<%= sale.productStatus %>" style="position:static; display:inline-block;"><%= sale.productStatus.replace('_', ' ') %></span>
            </div>
        </div>
    <% }); %>
</div>

<%- include('partials/footer') %>

</body>
</html>
