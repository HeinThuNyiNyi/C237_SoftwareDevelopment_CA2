<%
  // 星级右侧显示的英文含义，与浏览器端脚本中的文案保持一致。
  const ratingMeanings = ['Not rated', 'Poor', 'Fair', 'Good', 'Very good', 'Excellent'];
  const currentRating = Number(selectedRating || 0);
  const media = Array.isArray(existingMedia) ? existingMedia : [];
%>
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Rate a CampusCycle listing and share useful feedback with other students.">
  <title><%= pageTitle %> · CampusCycle</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="stylesheet" href="/css/rating.css">
</head>
<body>
  <a class="skip-link" href="#review-form">Skip to review form</a>

  <header class="review-header">
    <a class="back-button" href="/details/<%= itemId %>/ratings" aria-label="Back to item reviews">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M15 18l-6-6 6-6"></path>
      </svg>
    </a>
    <div>
      <p class="eyebrow">Verified buyer review</p>
      <h1><%= pageTitle %></h1>
    </div>
    <span class="header-spacer" aria-hidden="true"></span>
  </header>

  <main class="review-shell">
    <p class="review-notice">
      Your purchase is verified. Add clear evidence so other students can judge the item's condition.
    </p>

    <article class="item-summary" aria-label="Item being reviewed">
      <div class="item-thumbnail">
        <% if (item.image) { %>
          <img src="<%= item.image %>" alt="">
        <% } else { %>
          <span aria-hidden="true">&#9851;</span>
        <% } %>
      </div>
      <div class="item-copy">
        <span><%= item.category %></span>
        <strong><%= item.name %></strong>
      </div>
      <% if (item.price !== null) { %>
        <span class="item-price">$<%= Number(item.price).toFixed(2) %></span>
      <% } %>
    </article>

    <% if (success) { %>
      <div class="form-message is-success" role="status"><%= success %></div>
    <% } %>

    <% if (error) { %>
      <div class="form-message is-error" role="alert"><%= error %></div>
    <% } %>

    <form
      id="review-form"
      class="review-form"
      action="/details/<%= itemId %>/rating/new"
      method="POST"
      enctype="multipart/form-data"
    >
      <!-- 媒体选择区域：图片和视频使用不同字段，后端会统一保存到 rating_media。 -->
      <section class="form-section media-section" aria-labelledby="media-title">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Optional evidence</p>
            <h2 id="media-title">Show the item's condition</h2>
          </div>
          <span>Up to 25 MB each</span>
        </div>

        <div class="upload-grid">
          <label class="upload-tile" for="rating-images">
            <input
              id="rating-images"
              type="file"
              name="images"
              accept="image/*"
              multiple
              data-preview-target="image-previews"
            >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M4 7h3l1.5-2h7L17 7h3v12H4z"></path>
              <circle cx="12" cy="13" r="3.5"></circle>
            </svg>
            <strong>Add photos</strong>
            <span>Up to four images</span>
          </label>

          <label class="upload-tile" for="rating-video">
            <input
              id="rating-video"
              type="file"
              name="videos"
              accept="video/*"
              data-preview-target="video-previews"
            >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <rect x="3" y="6" width="13" height="12" rx="2"></rect>
              <path d="M16 10l5-3v10l-5-3z"></path>
            </svg>
            <strong>Add a short video</strong>
            <span>One video</span>
          </label>
        </div>

        <div class="media-previews" id="image-previews" aria-live="polite"></div>
        <div class="media-previews" id="video-previews" aria-live="polite"></div>

        <% if (media.length) { %>
          <div class="existing-media">
            <p>Your current attachments</p>
            <div class="existing-media-grid">
              <% media.forEach((file) => { %>
                <figure>
                  <% if (file.media_type === 'image') { %>
                    <img src="<%= file.file_path %>" alt="Previously uploaded review image">
                  <% } else { %>
                    <video src="<%= file.file_path %>" controls preload="metadata"></video>
                  <% } %>
                </figure>
              <% }) %>
            </div>
            <label class="remove-media-option">
              <input type="checkbox" name="removeMedia" value="1">
              Remove current attachments when I save
            </label>
          </div>
        <% } %>
      </section>

      <!-- 五颗星使用原生 radio，既能键盘操作，也能被 Express 通过 req.body.rating 读取。 -->
      <fieldset class="form-section rating-section">
        <legend>Your rating</legend>
        <div class="rating-row">
          <div class="star-picker" id="star-picker">
            <% for (let value = 1; value <= 5; value++) { %>
              <input
                type="radio"
                name="rating"
                id="rating-<%= value %>"
                value="<%= value %>"
                <%= currentRating === value ? 'checked' : '' %>
                required
              >
              <label
                class="star-button <%= value <= currentRating ? 'is-filled' : '' %>"
                for="rating-<%= value %>"
                data-rating="<%= value %>"
                aria-label="<%= value %> star<%= value > 1 ? 's' : '' %>"
              >★</label>
            <% } %>
          </div>
          <output id="rating-meaning" class="rating-meaning" for="star-picker">
            <%= ratingMeanings[currentRating] %>
          </output>
        </div>
        <p class="field-help">Choose one star for a poor experience or five for an excellent one.</p>
      </fieldset>

      <!-- 评论文字可手动输入，也可以由浏览器语音识别转成文字。 -->
      <section class="form-section comment-section" aria-labelledby="comment-title">
        <div class="section-heading compact">
          <div>
            <p class="section-kicker">Your experience</p>
            <h2 id="comment-title">Write a useful review</h2>
          </div>
          <span id="comment-count">0 / 500</span>
        </div>

        <textarea
          id="comment"
          name="comment"
          maxlength="500"
          rows="7"
          placeholder="Describe the item's condition, accuracy of the listing, and your experience with the seller."
        ><%= comment %></textarea>

        <div class="voice-row">
          <button id="voice-button" class="voice-button" type="button">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <rect x="9" y="3" width="6" height="11" rx="3"></rect>
              <path d="M5 11a7 7 0 0014 0M12 18v3M9 21h6"></path>
            </svg>
            <span>Voice input</span>
          </button>
          <span id="voice-status" class="voice-status" aria-live="polite">
            Speak naturally; your browser converts speech to text.
          </span>
        </div>
      </section>

      <section class="privacy-section">
        <label class="anonymous-option">
          <input
            type="checkbox"
            name="isAnonymous"
            value="1"
            <%= isAnonymous ? 'checked' : '' %>
          >
          <span class="custom-checkbox" aria-hidden="true"></span>
          <span>
            <strong>Post anonymously</strong>
            <small>Your name stays hidden from other students. Moderators can still review abuse reports.</small>
          </span>
        </label>
      </section>

      <button id="submit-review" class="submit-review" type="submit">
        <span><%= currentRating ? 'Update review' : 'Submit review' %></span>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6"></path>
        </svg>
      </button>
    </form>

    <% if (currentRating) { %>
      <form
        class="delete-review-form"
        action="/details/<%= itemId %>/rating/delete"
        method="POST"
        onsubmit="return confirm('Delete your review and all of its attachments?');"
      >
        <button class="delete-review-button" type="submit">Delete my review</button>
      </form>
    <% } %>
  </main>

  <script src="/js/rating.js" defer></script>
</body>
</html>
