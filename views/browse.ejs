<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Browse - CampusCycle</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar">
    <div class="brand">
        <div class="brand-icon">&#9851;</div>
        <span class="campus">Campus</span><span class="cycle">Cycle</span>
    </div>

    <div class="nav-links">
        <a href="/">Home</a>
        <a href="/browse">Browse</a>
        <a href="/wishlist">Wishlist</a>
        <a href="/cart">Cart</a>
        <a href="/sell" class="nav-cta">+ Sell an Item</a>
    </div>
</nav>

<section class="hero">
    <h1>Browse Listings</h1>
    <p>Find what you need from fellow students.</p>
</section>

<form action="/browse" method="GET" class="admin-section" style="padding-top:0; display:flex; gap:12px; flex-wrap:wrap; align-items:center;">
    <input type="text" name="q" value="<%= search %>" placeholder="Search by product name" class="reason-input" style="max-width:260px; margin-top:0;">

    <select name="category" class="ban-select" style="width:200px; margin-top:0;">
        <option value="">All Categories</option>
        <% categories.forEach(function(category) { %>
            <option value="<%= category.id %>" <% if (String(selectedCategory) === String(category.id)) { %>selected<% } %>><%= category.name %></option>
        <% }); %>
    </select>

    <button type="submit" class="btn-primary">Search</button>
    <a href="/browse" class="btn-outline">Clear</a>
</form>

<div class="section-title">
    <h2><%= products.length %> Listing<%= products.length === 1 ? '' : 's' %> Found</h2>
</div>

<div class="product-grid">

    <% if (products.length === 0) { %>
        <p>No listings match your search.</p>
    <% } %>

    <% products.forEach(function(product) { %>
        <div class="product-card">
            <div class="product-image">
                <img src="/images/<%= product.image %>" alt="<%= product.name %>" style="width:100%; height:100%; object-fit:cover;">
                <span class="status-badge status-<%= product.status %>"><%= product.status.replace('_', ' ') %></span>
                <button class="wishlist-btn" title="Add to wishlist">&#9825;</button>
            </div>
            <div class="product-body">
                <p class="product-title"><%= product.name %></p>
                <span class="condition-tag"><%= product.condition.replace('_', ' ') %></span>
                <p class="product-price">$<%= Number(product.price).toFixed(2) %></p>
                <p class="seller-info"><%= product.categoryName %> &middot; Seller: <%= product.sellerName %></p>
                <div class="product-actions-full">
                    <a href="/products/<%= product.id %>" class="btn-outline">View Details</a>
                    <button class="btn-report" title="Report this listing">&#9873;</button>
                </div>
            </div>
        </div>
    <% }); %>

</div>

<footer class="footer">
    &copy; 2026 <span class="brand-footer">CampusCycle</span> &mdash; Buy less. Reuse more.
</footer>

</body>
</html>
