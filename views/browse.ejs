<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Browse - CampusCycle</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('partials/navbar') %>

<% if (success) { %><p class="page-message is-success browse-message"><%= success %></p><% } %>
<% if (error) { %><p class="page-message is-error browse-message"><%= error %></p><% } %>

<form action="/browse" method="GET" class="filter-panel" aria-label="Filter marketplace listings">
    <label class="filter-field filter-search">
        <span>Search</span>
        <input type="search" name="q" value="<%= search %>" placeholder="Product name" class="reason-input">
    </label>
    <label class="filter-field">
        <span>Category</span>
        <select name="category" class="ban-select">
            <option value="">All categories</option>
            <% categories.forEach(function(category) { %>
                <option value="<%= category.id %>" <%= String(selectedCategory) === String(category.id) ? 'selected' : '' %>><%= category.name %></option>
            <% }); %>
        </select>
    </label>
    <label class="filter-field">
        <span>Minimum rating</span>
        <select name="minRating" class="ban-select">
            <option value="">Any rating</option>
            <% for (let rating = 5; rating >= 1; rating--) { %>
                <option value="<%= rating %>" <%= Number(selectedMinRating) === rating ? 'selected' : '' %>><%= rating %>&#9733; &amp; up</option>
            <% } %>
        </select>
    </label>
    <label class="filter-field">
        <span>Sort by</span>
        <select name="sort" class="ban-select">
            <option value="newest" <%= selectedSort === 'newest' ? 'selected' : '' %>>Newest</option>
            <option value="top_rated" <%= selectedSort === 'top_rated' ? 'selected' : '' %>>Top rated (weighted)</option>
            <option value="most_reviewed" <%= selectedSort === 'most_reviewed' ? 'selected' : '' %>>Most reviewed</option>
            <option value="price_low" <%= selectedSort === 'price_low' ? 'selected' : '' %>>Price: low to high</option>
            <option value="price_high" <%= selectedSort === 'price_high' ? 'selected' : '' %>>Price: high to low</option>
        </select>
    </label>
    <div class="filter-actions">
        <button type="submit" class="btn-primary">Apply filters</button>
        <a href="/browse" class="btn-outline">Reset</a>
    </div>
</form>

<div class="section-title"><h2><%= products.length %> listing<%= products.length === 1 ? '' : 's' %> found</h2></div>

<div class="product-grid">

    <% if (products.length === 0) { %>
        <p>No listings match your search.</p>
    <% } %>

    <% products.forEach(function(product) { %>
        <% const average = Number(product.ratingSummary.averageRating || 0); %>
        <% const count = Number(product.ratingSummary.reviewCount || 0); %>
        <div class="product-card">
            <div class="product-image">
                <img src="/images/<%= product.image %>" alt="<%= product.name %>" style="width:100%; height:100%; object-fit:cover;">
                <span class="status-badge status-<%= product.status %>"><%= product.status.replace('_', ' ') %></span>
                <% if (currentUser && Number(currentUser.id) !== Number(product.seller_id)) { %>
                    <form action="/wishlist/<%= product.isWishlisted ? 'remove' : 'add' %>/<%= product.id %>" method="POST" class="product-wishlist-form">
                        <input type="hidden" name="redirectTo" value="/browse">
                        <button
                            type="submit"
                            class="wishlist-btn <%= product.isWishlisted ? 'active-wishlist' : '' %>"
                            title="<%= product.isWishlisted ? 'Remove from wishlist' : 'Add to wishlist' %>"
                            aria-label="<%= product.isWishlisted ? 'Remove from wishlist' : 'Add to wishlist' %>"
                        ><%- product.isWishlisted ? '&#9829;' : '&#9825;' %></button>
                    </form>
                <% } else if (!currentUser) { %>
                    <a href="/login" class="wishlist-btn" title="Log in to add to wishlist" aria-label="Log in to add to wishlist">&#9825;</a>
                <% } %>
            </div>
            <div class="product-body">
                <p class="product-title"><%= product.name %></p>
                <span class="condition-tag"><%= product.condition.replace('_', ' ') %></span>
                <p class="product-price">$<%= Number(product.price).toFixed(2) %></p>
                <p class="seller-info"><%= product.categoryName %> &middot; Seller: <%= product.sellerName %> &middot; <a href="/users/<%= product.seller_id %>">View Profile</a></p>

                <!-- Rating comes from the ratings table; the link only opens the public reviews list. -->
                <a href="/details/<%= product.id %>/ratings" class="rating" aria-label="<%= count ? `${average} out of 5 from ${count} reviews` : 'No verified reviews yet' %>">
                    <span class="rating-stars" aria-hidden="true">
                        <% for (let star = 1; star <= 5; star++) { %>
                            <span class="<%= star <= Math.round(average) ? 'is-filled' : '' %>">★</span>
                        <% } %>
                    </span>
                    <strong><%= average.toFixed(1) %></strong>
                    <span class="count">(<%= count %>)</span>
                </a>

                <div class="product-actions-full">
                    <a href="/products/<%= product.id %>" class="btn-outline">View Details</a>
                    <a href="/user_report/<%= product.id %>" class="btn-report" title="Report this listing">&#9873;</a>
                </div>
            </div>
        </div>
    <% }); %>

</div>

<footer class="footer">
    &copy; 2026 <span class="brand-footer">CampusCycle</span> &mdash; Buy less. Reuse more.
</footer>

</body>
</html>
