<%- include('../partials/head', { title: 'Log In' }) %>
<%- include('../partials/navbar') %>
<main class="container py-5 page-shell">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <%- include('../partials/messages') %>
            <%- include('../partials/back-button', { backUrl: '/' }) %>
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h3 mb-4">Log in</h1>
                    <form method="POST" action="/login">
                        <div class="mb-3">
                            <label class="form-label">RP email</label>
                            <input class="form-control" type="email" name="email" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            <input class="form-control" type="password" name="password" required>
                        </div>
                        <button class="btn btn-success w-100">Log In</button>
                    </form>
                    <p class="mt-3 mb-0">New student? <a href="/register">Create an account</a>.</p>
                </div>
            </div>
        </div>
    </div>
</main>
<%- include('../partials/footer') %>
