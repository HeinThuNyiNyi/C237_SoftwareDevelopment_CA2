<%- include('../partials/head', { title: 'Sign Up' }) %>
<%- include('../partials/navbar') %>
<main class="container py-5 page-shell">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">
            <%- include('../partials/messages') %>
            <%- include('../partials/back-button', { backUrl: '/' }) %>
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h3 mb-4">Student registration</h1>
                    <form method="POST" action="/register">
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <input class="form-control" name="name" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">RP email</label>
                            <input class="form-control" type="email" name="email" placeholder="name@myrp.edu.sg" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Phone</label>
                            <input class="form-control" name="phone">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            <input class="form-control" type="password" name="password" minlength="6" required>
                        </div>
                        <button class="btn btn-success w-100">Create Account</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>
<%- include('../partials/footer') %>
