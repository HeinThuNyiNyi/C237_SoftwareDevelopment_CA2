<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Report User - CampusCycle</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('../partials/navbar') %>

<section class="hero">
    <h1>Report a User</h1>
    <p>Tell us what happened and our admins will look into this account.</p>
</section>

<div class="admin-section">
    <div class="review-card">
        <div class="review-thumb">&#128100;</div>
        <div class="review-body">
            <h4>You are reporting: <%= reportedUser.name %></h4>
            <p class="review-meta"><%= reportedUser.email %></p>
        </div>
    </div>

    <div class="review-card form-card">
        <form action="/report_user" method="POST" enctype="multipart/form-data">
            <input type="hidden" name="reported_user_id" value="<%= reportedUser.id %>">

            <div style="margin-bottom:14px;">
                <label for="category">Reason</label><br>
                <select name="category" id="category" class="ban-select" required>
                    <option value="">-- Select --</option>
                    <option value="scam">Scam / fraud</option>
                    <option value="harassment">Harassment / abusive behaviour</option>
                    <option value="no_show">Did not show up for appointment</option>
                    <option value="fake_account">Suspicious / fake account</option>
                    <option value="other">Other</option>
                </select>
            </div>

            <div style="margin-bottom:14px;">
                <label for="description">Description</label><br>
                <textarea name="description" id="description" class="reason-input" rows="4" required></textarea>
            </div>

            <div style="margin-bottom:14px;">
                <label for="evidenceImage">Evidence (optional screenshot/photo)</label><br>
                <input type="file" id="evidenceImage" name="evidenceImage" accept="image/*">
            </div>

            <button type="submit" class="btn-primary">Submit Report</button>
            <a href="/" class="btn-outline">Cancel</a>
        </form>
    </div>
</div>

<footer class="footer">
    &copy; 2026 <span class="brand-footer">CampusCycle</span> &mdash; Buy less. Reuse more.
</footer>

</body>
</html>
