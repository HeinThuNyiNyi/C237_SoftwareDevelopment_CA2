<%
    const normalizeMessages = (messages) => {
        if (!messages) return [];
        return Array.isArray(messages) ? messages : [messages];
    };
    const normalizedSuccessMessages = normalizeMessages(successMessages);
    const normalizedErrorMessages = normalizeMessages(errorMessages);
%>
<% normalizedSuccessMessages.forEach(function(message) { %>
    <div class="alert alert-success"><%= message %></div>
<% }); %>
<% normalizedErrorMessages.forEach(function(message) { %>
    <div class="alert alert-error"><%= message %></div>
<% }); %>
