<%
    const numericValue = Number(value || 0);
    const filledStars = Math.round(numericValue);
    const starsClass = containerClass || 'stars-display';
    const accessibilityLabel = label || `${numericValue} out of 5 stars`;
%>
<span class="<%= starsClass %>" role="img" aria-label="<%= accessibilityLabel %>">
    <% for (let star = 1; star <= 5; star++) { %>
        <span class="<%= star <= filledStars ? 'is-filled' : '' %>" aria-hidden="true">&#9733;</span>
    <% } %>
</span>
