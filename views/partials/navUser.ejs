<%
// ============================================================
// Navbar user corner  (Hein Thu Nyi Nyi)
//
// Logged in  -> circular avatar with the user's initials, opening a menu.
// Logged out -> Log in / Sign up buttons.
//
// currentUser is set for every page by the res.locals middleware in
// app.js, so including this partial needs no extra route changes.
// ============================================================
%>
<% if (currentUser) { %>

    <div class="nav-user">
        <button type="button" class="nav-avatar" aria-label="Account menu">
            <%= currentUser.initials %>
        </button>

        <div class="nav-user-menu">
            <div class="nav-user-head">
                <span class="nav-user-name"><%= currentUser.name %></span>
                <span class="nav-user-email"><%= currentUser.email %></span>
            </div>

            <a href="/profile">My Profile</a>
            <a href="/users/<%= currentUser.id %>">Public Profile</a>
            <a href="/reservations">My Reservations</a>
            <a href="/my_reports">My Reports</a>

            <% if (currentUser.role === 'admin') { %>
                <a href="/admin">Admin Dashboard</a>
            <% } %>

            <div class="nav-user-divider"></div>
            <a href="/logout" class="nav-user-logout">Log Out</a>
        </div>
    </div>

<% } else { %>

    <a href="/login" class="nav-login-link">Log In</a>
    <a href="/register" class="nav-signup-btn">Sign Up</a>

<% } %>
