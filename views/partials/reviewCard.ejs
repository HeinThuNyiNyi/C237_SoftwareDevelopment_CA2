<%
    const compactCard = Boolean(compact);
    const wrapperClass = compactCard ? 'pubprof-review' : 'review-card';
    const bodyClass = compactCard ? 'review-compact-body' : 'review-body';
%>
<div class="<%= wrapperClass %>">
    <% if (!compactCard && showImage) { %>
        <div class="review-thumb">
            <% if (review.image) { %>
                <img class="review-image" src="<%= review.image %>" alt="Photo from <%= review.authorLabel %>">
            <% } else { %>
                &#9733;
            <% } %>
        </div>
    <% } %>

    <div class="<%= bodyClass %>">
        <div class="<%= compactCard ? 'pubprof-review-head' : 'review-card-head' %>">
            <strong><%= review.authorLabel %></strong>
            <% if (showProduct && review.productName) { %>
                <span class="pubprof-review-product">on <%= review.productName %></span>
            <% } %>
        </div>

        <%- include('./stars', {
            value: review.rating,
            containerClass: compactCard ? 'pubprof-review-stars' : 'stars-display',
            label: `${review.rating} out of 5 stars`
        }) %>

        <% if (showDate) { %>
            <p class="review-meta"><%= new Date(review.updatedAt).toLocaleDateString() %></p>
        <% } %>

        <% if (review.comment || emptyCommentText) { %>
            <p class="<%= compactCard ? 'pubprof-review-comment' : 'review-comment' %>">
                <%= review.comment || emptyCommentText %>
            </p>
        <% } %>
    </div>
</div>
