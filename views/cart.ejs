<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shopping Cart - CampusCycle</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('partials/navbar') %>

<main class="page-container">
    <div class="page-header">
        <h1>Shopping Cart</h1>
        <p>Review products and adjust quantities before making a reservation.</p>
    </div>

    <% if (success_msg && success_msg.length > 0) { %>
        <div class="alert alert-success"><%= success_msg[0] %></div>
    <% } %>

    <% if (error_msg && error_msg.length > 0) { %>
        <div class="alert alert-error"><%= error_msg[0] %></div>
    <% } %>

    <% if (cartItems && cartItems.length > 0) { %>
        <div class="cart-layout">
            <div class="cart-table-wrapper">
                <table class="cart-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Unit Price</th>
                            <th>Quantity</th>
                            <th>Subtotal</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% cartItems.forEach(item => { %>
                            <tr>
                                <td class="cart-product-info">
                                    <div class="cart-product-icon">
                                        <% if (item.image) { %>
                                            <img src="/images/products/<%= item.image %>" alt="<%= item.name %>">
                                        <% } else { %>
                                            <span>&#128230;</span>
                                        <% } %>
                                    </div>
                                    <div>
                                        <a href="/products/<%= item.product_id %>" class="cart-product-name"><%= item.name %></a>
                                        <div class="cart-product-cat"><%= item.category || 'General' %></div>
                                    </div>
                                </td>
                                <td class="price-cell">$<%= Number(item.price).toFixed(2) %></td>
                                <td>
                                    <div class="qty-control">
                                        <form action="/cart/decrease/<%= item.product_id %>" method="POST">
                                            <button type="submit" class="qty-btn" title="Decrease quantity">-</button>
                                        </form>
                                        <span class="qty-val"><%= item.quantity %></span>
                                        <form action="/cart/increase/<%= item.product_id %>" method="POST">
                                            <button type="submit" class="qty-btn" title="Increase quantity">+</button>
                                        </form>
                                    </div>
                                </td>
                                <td class="subtotal-cell">$<%= Number(item.subtotal).toFixed(2) %></td>
                                <td>
                                    <form action="/cart/remove/<%= item.product_id %>" method="POST">
                                        <button type="submit" class="btn-danger">Remove</button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <aside class="cart-summary-card">
                <h2>Order Summary</h2>
                <div class="summary-row">
                    <span>Items subtotal</span>
                    <span class="summary-val">$<%= totalAmount %></span>
                </div>
                <hr class="summary-divider">
                <div class="summary-row total-row">
                    <span>Total amount</span>
                    <span class="summary-total">$<%= totalAmount %></span>
                </div>
                <p class="cart-summary-note">Open a product to submit a reservation request and arrange collection with its seller.</p>
                <a href="/browse" class="btn-primary">Continue Browsing</a>
            </aside>
        </div>
    <% } else { %>
        <div class="empty-state-card">
            <div class="empty-icon">&#128722;</div>
            <h2>Your shopping cart is empty</h2>
            <p>Explore available products and add something to your cart.</p>
            <a href="/browse" class="btn-primary">Browse Marketplace</a>
        </div>
    <% } %>
</main>

<footer class="footer">
    &copy; 2026 <span class="brand-footer">CampusCycle</span> &mdash; Buy less. Reuse more.
</footer>

</body>
</html>
