<%- include('partials/head', { title: 'Cart' }) %>
<%- include('partials/navbar') %>
<main class="container py-4 page-shell">
    <%- include('partials/messages') %>
    <%- include('partials/back-button', { backUrl: '/' }) %>
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <h1 class="h3 mb-1">Cart</h1>
            <p class="text-secondary mb-0">Use the cart for products you intend to reserve soon. Use the wishlist for longer-term interests.</p>
        </div>
        <% if (items.length > 0) { %>
            <button class="btn btn-success" type="button" data-bs-toggle="modal" data-bs-target="#reserveAllModal">
                Reserve All
            </button>
        <% } %>
    </div>
    <% if (items.length === 0) { %><div class="alert alert-info">Your cart is empty.</div><% } %>
    <div class="table-responsive">
        <table class="table bg-white">
            <thead><tr><th>Product</th><th>Price</th><th>Available</th><th>Quantity</th><th>Actions</th></tr></thead>
            <tbody>
                <% items.forEach(function(item) { %>
                    <tr>
                        <td><a href="/products/<%= item.product_id %>"><%= item.name %></a><small class="d-block text-secondary"><%= item.seller_name %></small></td>
                        <td>$<%= Number(item.price).toFixed(2) %></td>
                        <td><%= item.available_quantity %></td>
                        <td>
                            <form class="d-flex gap-2" method="POST" action="/cart/update/<%= item.cart_id %>">
                                <input class="form-control form-control-sm" style="max-width:90px" type="number" name="quantity" min="1" max="<%= item.available_quantity %>" value="<%= item.cart_quantity %>">
                                <button class="btn btn-sm btn-outline-primary">Update</button>
                            </form>
                        </td>
                        <td>
                            <form class="d-inline" method="POST" action="/cart/reserve/<%= item.cart_id %>">
                                <button class="btn btn-sm btn-success" <%= item.status !== 'approved' || item.cart_quantity > item.available_quantity ? 'disabled' : '' %>>Reserve</button>
                            </form>
                            <form class="d-inline" method="POST" action="/cart/delete/<%= item.cart_id %>">
                                <button class="btn btn-sm btn-outline-danger">Remove</button>
                            </form>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>

    <% if (items.length > 0) { %>
        <div class="modal fade" id="reserveAllModal" tabindex="-1" aria-labelledby="reserveAllTitle" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h2 class="modal-title fs-5" id="reserveAllTitle">Reserve all cart products?</h2>
                        <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        A separate reservation will be created for every available cart product.
                        Products that are no longer available will remain in your cart.
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                        <form method="POST" action="/cart/reserve-all">
                            <button class="btn btn-success" type="submit">Reserve All</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    <% } %>
</main>
<%- include('partials/footer') %>
