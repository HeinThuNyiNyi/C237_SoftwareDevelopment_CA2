<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CampusCycle</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar">
    <div class="brand">
        <div class="brand-icon">&#9851;</div>
        <span class="campus">Campus</span><span class="cycle">Cycle</span>
    </div>

    <div class="nav-links">
        <a href="/">Home</a>

        <div class="dropdown">
            <a href="/browse">Browse</a>
            <div class="dropdown-menu">
                <a href="/browse?category=electronics">Electronics</a>
                <a href="/browse?category=books">Textbooks</a>
                <a href="/browse?category=furniture">Furniture</a>
                <a href="/browse?category=clothing">Clothing</a>
            </div>
        </div>

        <a href="/wishlist">Wishlist</a>

        <div class="dropdown">
            <a href="/profile">Account</a>
            <div class="dropdown-menu">
                <a href="/profile">My Profile</a>
                <a href="/loans">My Listings</a>
                <a href="/notifications">Notifications</a>
                <a href="/logout">Logout</a>
            </div>
        </div>

        <a href="/sell" class="nav-cta">+ Sell an Item</a>
    </div>
</nav>

<section class="hero">
    <h1>Give it a <span class="highlight">second life</span> on campus</h1>
    <p>Buy, sell and swap with fellow students &mdash; sustainably.</p>
</section>

<div class="section-title">
    <h2>Recently Listed</h2>
</div>

<div class="product-grid">
    <div class="product-card">
        <div class="product-image">
            &#128187;
            <button class="wishlist-btn" title="Add to wishlist">&#9825;</button>
        </div>
        <div class="product-body">
            <p class="product-title">Dell Latitude 5420 Laptop</p>
            <p class="product-price">$320</p>
            <p class="rating">&#9733;&#9733;&#9733;&#9733;&#9734; <span class="count">(18)</span></p>
            <div class="product-actions">
                <button class="add-to-cart">Add to Cart</button>
                <button class="report-btn" title="Report this listing">&#9873;</button>
            </div>
        </div>
    </div>
</div>

<footer class="footer">
    &copy; 2026 <span class="brand-footer">CampusCycle</span> &mdash; Buy less. Reuse more.
</footer>

</body>
</html>
