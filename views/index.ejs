<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CampusCycle</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar">
    <div class="brand">
        <div class="brand-icon">&#9851;</div>
        <span class="campus">Campus</span><span class="cycle">Cycle</span>
    </div>

    <div class="nav-links">
        <a href="/">Home</a>

        <div class="dropdown">
            <a href="/browse">Browse</a>
            <div class="dropdown-menu">
                <% categories.forEach(function(category) { %>
                    <a href="/browse?category=<%= category.id %>"><%= category.name %></a>
                <% }); %>
            </div>
        </div>

        <a href="/wishlist">Wishlist</a>
        <a href="/cart">Cart</a>

        <div class="dropdown">
            <a href="/profile">Account</a>
            <div class="dropdown-menu">
                <a href="/profile">My Profile</a>
                <a href="/my-listings">My Listings</a>
                <a href="/purchase-history">Purchase History</a>
                <a href="/sales-history">Sales History</a>
                <a href="/reservations">My Reservations</a>
                <a href="/notifications">Notifications</a>
                <a href="/logout">Logout</a>
            </div>
        </div>

        <a href="/sell" class="nav-cta">+ Sell an Item</a>
    </div>
</nav>

<section class="hero">
    <h1>Give it a <span class="highlight">second life</span> on campus</h1>
    <p>Buy, sell and swap with fellow students &mdash; sustainably.</p>
</section>

<div class="section-title">
    <h2>Recently Listed</h2>
</div>

<div class="product-grid">

    <% if (products.length === 0) { %>
        <p>No listings yet. Be the first to <a href="/sell">sell an item</a>!</p>
    <% } %>

    <% products.forEach(function(product) { %>
        <div class="product-card">
            <div class="product-image">
                <img src="/images/<%= product.image %>" alt="<%= product.name %>" style="width:100%; height:100%; object-fit:cover;">
                <span class="status-badge status-<%= product.status %>"><%= product.status.replace('_', ' ') %></span>
                <button class="wishlist-btn" title="Add to wishlist">&#9825;</button>
            </div>
            <div class="product-body">
                <p class="product-title"><%= product.name %></p>
                <span class="condition-tag"><%= product.condition.replace('_', ' ') %></span>
                <p class="product-price">$<%= Number(product.price).toFixed(2) %></p>
                <p class="seller-info">Seller: <%= product.sellerName %></p>
                <div class="product-actions-full">
                    <a href="/products/<%= product.id %>" class="btn-outline">View Details</a>
                    <a href="/user_report/<%= product.id %>" class="btn-report" title="Report this listing">&#9873;</a>
                </div>
            </div>
        </div>
    <% }); %>

</div>

<footer class="footer">
    &copy; 2026 <span class="brand-footer">CampusCycle</span> &mdash; Buy less. Reuse more.
</footer>

</body>
</html>
