<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CampusCycle</title>
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar">
    <a class="brand" href="/">
        <span class="brand-icon">&#9851;</span>
        <span><span class="campus">Campus</span><span class="cycle">Cycle</span></span>
    </a>
    <div class="nav-links">
        <a href="/">Home</a>
        <div class="dropdown">
            <a href="/browse">Browse</a>
            <div class="dropdown-menu">
                <% categories.forEach((category) => { %>
                    <a href="/browse?category=<%= category.id %>"><%= category.name %></a>
                <% }) %>
            </div>
        </div>
        <a href="/wishlist">Wishlist</a>
        <a href="/cart">Cart</a>
        <div class="dropdown">
            <a href="/profile">Account</a>
            <div class="dropdown-menu">
                <a href="/profile">My Profile</a>
                <a href="/my-listings">My Listings</a>
                <a href="/purchase-history">Purchase History</a>
                <a href="/sales-history">Sales History</a>
                <a href="/reservations">My Reservations</a>
                <a href="/notifications">Notifications</a>
                <a href="/logout">Logout</a>
            </div>
        </div>
        <a href="/sell" class="nav-cta">+ Sell an Item</a>
    </div>
</nav>

<section class="hero">
    <h1>Give it a <span class="highlight">second life</span> on campus</h1>
    <p>Buy, sell and swap with fellow students &mdash; sustainably.</p>
</section>

<div class="section-title">
    <h2>Recently Listed</h2>
    <a href="/browse" class="section-link">Browse all</a>
</div>

<div class="product-grid">
    <% if (!products.length) { %>
        <p class="empty-state">No approved listings yet. Be the first to <a href="/sell">sell an item</a>.</p>
    <% } %>

    <% products.forEach((product) => { %>
        <% const average = Number(product.ratingSummary.averageRating || 0); %>
        <% const count = Number(product.ratingSummary.reviewCount || 0); %>
        <% const filledStars = Math.round(average); %>
        <article class="product-card">
            <a class="product-image" href="/products/<%= product.id %>">
                <% if (product.image) { %>
                    <img src="/images/<%= product.image %>" alt="<%= product.name %>">
                <% } else { %>
                    <span class="image-placeholder" aria-hidden="true">&#9851;</span>
                <% } %>
                <span class="status-badge status-<%= product.status %>"><%= product.status.replace('_', ' ') %></span>
            </a>
            <button class="wishlist-btn" title="Add to wishlist">&#9825;</button>
            <div class="product-body">
                <span class="condition-tag"><%= product.condition.replace('_', ' ') %></span>
                <p class="product-title"><%= product.name %></p>
                <p class="product-price">$<%= Number(product.price).toFixed(2) %></p>
                <p class="seller-info">Seller: <%= product.sellerName %></p>

                <a href="/details/<%= product.id %>/ratings" class="rating" aria-label="<%= count ? `${average} out of 5 from ${count} reviews` : 'No verified reviews yet' %>">
                    <span class="rating-stars" aria-hidden="true">
                        <% for (let star = 1; star <= 5; star++) { %>
                            <span class="<%= star <= filledStars ? 'is-filled' : '' %>">★</span>
                        <% } %>
                    </span>
                    <strong><%= average.toFixed(1) %></strong>
                    <span class="count">(<%= count %>)</span>
                </a>

                <div class="product-actions-full">
                    <a href="/products/<%= product.id %>" class="btn-outline">View Details</a>
                    <button class="btn-report" title="Report this listing">&#9873;</button>
                </div>
            </div>
        </article>
    <% }) %>
</div>

<footer class="footer">
    &copy; 2026 <span class="brand-footer">CampusCycle</span> &mdash; Buy less. Reuse more.
</footer>
</body>
</html>
