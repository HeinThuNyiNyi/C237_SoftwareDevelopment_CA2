<%- include('../partials/head', { title: 'Reservation Details' }) %>
<%- include('../partials/navbar') %>
<main class="container py-4 page-shell">
    <%- include('../partials/messages') %>
    <%- include('../partials/back-button', { backUrl: '/reservations' }) %>
    <% const statusColours = {
        requested: 'info',
        proposed: 'warning',
        confirmed: 'primary',
        completed: 'success',
        cancelled: 'secondary',
        rejected: 'danger'
    }; %>
    <div class="card shadow-sm"><div class="card-body p-4">
        <div class="d-flex justify-content-between">
            <h1 class="h3"><%= reservation.product_name %></h1>
            <span class="badge status-badge text-bg-<%= statusColours[reservation.status] || 'secondary' %>"><%= reservation.status %></span>
        </div>
        <dl class="row mt-4">
            <dt class="col-sm-4">Buyer</dt><dd class="col-sm-8"><%= reservation.buyer_name %></dd>
            <dt class="col-sm-4">Seller</dt><dd class="col-sm-8"><%= reservation.seller_name %></dd>
            <dt class="col-sm-4">Quantity</dt><dd class="col-sm-8"><%= reservation.quantity %></dd>
            <dt class="col-sm-4">Total price</dt><dd class="col-sm-8">$<%= Number(reservation.total_price).toFixed(2) %></dd>
            <dt class="col-sm-4">Meetup</dt>
            <dd class="col-sm-8">
                <% if (reservation.appointment_date) { %>
                    <%= new Date(reservation.appointment_date).toLocaleDateString() %>,
                    <%= String(reservation.appointment_time).slice(0,5) %> at <%= reservation.meeting_location %>
                <% } else { %>Not proposed yet<% } %>
            </dd>
        </dl>

        <div class="d-flex flex-wrap gap-2">
            <% if (currentUser.id === reservation.seller_id && ['requested', 'proposed'].includes(reservation.status)) { %>
                <a class="btn btn-primary" href="/reservations/<%= reservation.id %>/edit">Propose Meetup</a>
                <form method="POST" action="/reservations/<%= reservation.id %>/reject"><button class="btn btn-outline-danger">Reject</button></form>
            <% } %>
            <% if (currentUser.id === reservation.buyer_id && reservation.status === 'proposed') { %>
                <form method="POST" action="/reservations/<%= reservation.id %>/confirm"><button class="btn btn-success">Confirm</button></form>
            <% } %>
            <% if (currentUser.id === reservation.buyer_id && ['requested', 'proposed', 'confirmed'].includes(reservation.status)) { %>
                <form method="POST" action="/reservations/<%= reservation.id %>/cancel"><button class="btn btn-outline-danger">Cancel</button></form>
            <% } %>
            <% if (currentUser.id === reservation.seller_id && reservation.status === 'confirmed') { %>
                <form method="POST" action="/reservations/<%= reservation.id %>/complete"><button class="btn btn-success">Mark Completed</button></form>
            <% } %>
            <% if (['cancelled', 'rejected'].includes(reservation.status)) { %>
                <form method="POST" action="/reservations/<%= reservation.id %>/delete" onsubmit="return confirm('Delete this reservation record?')">
                    <button class="btn btn-danger">Delete Record</button>
                </form>
            <% } %>
        </div>
    </div></div>
</main>
<%- include('../partials/footer') %>
