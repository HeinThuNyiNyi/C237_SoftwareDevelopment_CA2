<%- include('../partials/head', { title: 'Propose Meetup' }) %>
<%- include('../partials/navbar') %>
<main class="container py-4 page-shell">
    <div class="row justify-content-center"><div class="col-lg-7">
        <%- include('../partials/messages') %>
        <%- include('../partials/back-button', { backUrl: '/reservations/' + reservation.id }) %>
        <div class="card shadow-sm"><div class="card-body p-4">
            <h1 class="h3">Propose meetup for <%= reservation.product_name %></h1>
            <form method="POST" action="/reservations/<%= reservation.id %>/edit">
                <div class="mb-3">
                    <label class="form-label">Date</label>
                    <input class="form-control" type="date" name="appointmentDate" value="<%= reservation.appointment_date ? new Date(reservation.appointment_date).toISOString().slice(0,10) : '' %>" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Time</label>
                    <input class="form-control" type="time" name="appointmentTime" value="<%= reservation.appointment_time ? String(reservation.appointment_time).slice(0,5) : '' %>" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Campus location</label>
                    <input class="form-control" name="meetingLocation" value="<%= reservation.meeting_location || '' %>" required>
                </div>
                <button class="btn btn-success">Send Proposal</button>
            </form>
        </div></div>
    </div></div>
</main>
<%- include('../partials/footer') %>
