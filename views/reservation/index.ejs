<%- include('../partials/head', { title: 'Reservations' }) %>
<%- include('../partials/navbar') %>
<main class="container py-4 page-shell">
    <%- include('../partials/messages') %>
    <%- include('../partials/back-button', { backUrl: '/' }) %>
    <h1 class="h3 mb-3">My reservations</h1>
    <% const statusColours = {
        requested: 'info',
        proposed: 'warning',
        confirmed: 'primary',
        completed: 'success',
        cancelled: 'secondary',
        rejected: 'danger'
    }; %>
    <% if (reservations.length === 0) { %><div class="alert alert-info">No reservations yet.</div><% } %>
    <div class="table-responsive">
        <table class="table table-striped bg-white">
            <thead><tr><th>Product</th><th>Buyer / Seller</th><th>Total</th><th>Status</th><th>Action</th></tr></thead>
            <tbody>
                <% reservations.forEach(function(item) { %>
                    <tr>
                        <td><%= item.product_name %> × <%= item.quantity %></td>
                        <td>
                            <% if (currentUser.id === item.buyer_id) { %>
                                Seller: <%= item.seller_name %>
                            <% } else { %>
                                Buyer: <%= item.buyer_name %>
                            <% } %>
                        </td>
                        <td>$<%= Number(item.total_price).toFixed(2) %></td>
                        <td><span class="badge status-badge text-bg-<%= statusColours[item.status] || 'secondary' %>"><%= item.status %></span></td>
                        <td>
                            <a class="btn btn-sm btn-outline-success" href="/reservations/<%= item.id %>">View</a>
                            <% if (item.status === 'completed' && currentUser.id === item.buyer_id && !item.rating_id) { %>
                                <a class="btn btn-sm btn-warning" href="/reservations/<%= item.id %>/rating">Rate</a>
                            <% } %>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</main>
<%- include('../partials/footer') %>
