<%- include('partials/head', { title: 'My Profile' }) %>
<%- include('partials/navbar') %>
<main class="container py-4 page-shell">
    <%- include('partials/messages') %>
    <%- include('partials/back-button', { backUrl: '/' }) %>
    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card shadow-sm"><div class="card-body p-4">
                <h1 class="h3">My profile</h1>
                <form method="POST" action="/profile/update">
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input class="form-control" name="name" value="<%= profile.name %>" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input class="form-control" value="<%= profile.email %>" disabled>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Phone</label>
                        <input class="form-control" name="phone" value="<%= profile.phone || '' %>">
                    </div>
                    <button class="btn btn-success">Update Profile</button>
                </form>
            </div></div>
        </div>
        <div class="col-lg-6">
            <div class="card shadow-sm mb-4"><div class="card-body p-4">
                <h2 class="h4">Change password</h2>
                <form method="POST" action="/profile/password">
                    <input class="form-control mb-3" type="password" name="currentPassword" placeholder="Current password" required>
                    <input class="form-control mb-3" type="password" name="newPassword" minlength="6" placeholder="New password" required>
                    <button class="btn btn-outline-success">Change Password</button>
                </form>
            </div></div>
            <% if (profile.role === 'user') { %>
                <div class="card border-danger"><div class="card-body">
                    <h2 class="h5 text-danger">Close account</h2>
                    <p class="small">Accounts with protected reservation history may not be deleted.</p>
                    <form method="POST" action="/profile/delete" onsubmit="return confirm('Permanently delete your account?')">
                        <button class="btn btn-danger">Delete Account</button>
                    </form>
                </div></div>
            <% } %>
        </div>
    </div>
</main>
<%- include('partials/footer') %>
