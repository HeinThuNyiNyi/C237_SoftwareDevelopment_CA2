<%
    const average = Number((ratingSummary && ratingSummary.averageRating) || 0);
    const reviewCount = Number((ratingSummary && ratingSummary.reviewCount) || 0);
%>
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= product.name %> - CampusCycle</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('../partials/navbar') %>

<!-- ============================================================
     Seller bar (Hein Thu Nyi Nyi)
     Sits above the listing so a buyer can see who is selling and open
     their profile. Hidden if the seller could not be loaded.
     The "Seller history" button is left inactive for Thiha Aung.
     ============================================================ -->
<% if (sellerInfo) { %>
<div class="sellerbar">
    <a href="/users/<%= sellerInfo.id %>" class="sellerbar-main">
        <div class="sellerbar-avatar"><%= sellerInfo.initials %></div>

        <div class="sellerbar-info">
            <div class="sellerbar-name-row">
                <span class="sellerbar-name"><%= sellerInfo.name %></span>
                <% if (sellerInfo.isGoodSeller) { %>
                    <span class="sellerbar-badge">Highly rated seller</span>
                <% } %>
            </div>

            <div class="sellerbar-meta">
                <span><%= sellerInfo.lastSeen %></span>
                <span class="sellerbar-sep">|</span>
                <span>Member for <%= sellerInfo.membershipLength %></span>
                <span class="sellerbar-sep">|</span>
                <span><%= sellerInfo.itemsSold %> sold</span>
                <% if (sellerInfo.reviewCount > 0) { %>
                    <span class="sellerbar-sep">|</span>
                    <span><%= sellerInfo.positivePercent %>% positive</span>
                <% } else { %>
                    <span class="sellerbar-sep">|</span>
                    <span>No reviews yet</span>
                <% } %>
            </div>
        </div>
    </a>

    <div class="sellerbar-actions">
        <a href="/users/<%= sellerInfo.id %>" class="sellerbar-btn">View profile</a>
        <button class="sellerbar-btn" disabled>Seller history</button>
    </div>
</div>
<% } %>

<div class="admin-section">
    <%- include('../partials/flashMessages', {
        successMessages: success,
        errorMessages: errors
    }) %>

    <div class="review-card">
        <div class="review-thumb" style="width:220px; height:220px;">
            <img src="/images/products/<%= product.image %>" alt="<%= product.name %>" style="width:100%; height:100%; object-fit:cover; border-radius:12px;">
        </div>

        <div class="review-body" style="min-width:280px;">
            <span class="status-badge status-<%= product.status %>" style="position:static; display:inline-block; margin-bottom:8px;"><%= product.status.replace('_', ' ') %></span>

            <h4 style="font-size:22px;"><%= product.name %></h4>
            <span class="condition-tag"><%= product.condition.replace('_', ' ') %></span>

            <p class="product-price" style="font-size:22px; margin:10px 0;">$<%= Number(product.price).toFixed(2) %></p>

            <p class="review-meta">Category: <%= product.categoryName %></p>
            <p class="review-meta">Quantity available: <%= product.quantity %></p>
            <p class="review-meta">Seller: <%= product.sellerName %></p>
            <p class="review-meta">Contact: <%= product.contact_info %></p>

            <p style="margin-top:14px;"><%= product.description %></p>

            <!-- Rating summary comes from the ratings table; the link only opens the public reviews list. -->
            <a href="/details/<%= product.id %>/ratings" class="rating product-rating-link">
                <%- include('../partials/stars', {
                    value: average,
                    containerClass: 'rating-stars',
                    label: `${average} out of 5 stars`
                }) %>
                <strong><%= average.toFixed(1) %></strong>
                <span class="count"><%= reviewCount %> verified review<%= reviewCount === 1 ? '' : 's' %></span>
            </a>

            <div class="product-actions-full" style="margin-top:18px;">
                <% if (!currentUser) { %>
                    <a href="/login" class="btn-outline">&#9825; Log in to Save</a>
                    <a href="/login" class="btn-primary">Log in to Add to Cart</a>
                <% } else if (currentUser.id === product.seller_id) { %>
                    <button class="btn-outline" disabled>Your Product</button>
                    <button class="btn-primary" disabled>Your Product</button>
                <% } else { %>
                    <% if (['selling', 'reserved'].includes(product.status)) { %>
                        <form action="/wishlist/add/<%= product.id %>" method="POST">
                            <button type="submit" class="btn-outline">&#9825; Add to Wishlist</button>
                        </form>
                    <% } else { %>
                        <button class="btn-outline" disabled>Cannot Save</button>
                    <% } %>

                    <% if (product.status === 'selling' && product.quantity > 0) { %>
                        <form action="/cart/add/<%= product.id %>" method="POST">
                            <button type="submit" class="btn-primary">Add to Cart</button>
                        </form>
                    <% } else { %>
                        <button class="btn-primary" disabled>Unavailable</button>
                    <% } %>
                <% } %>
                <% if (product.status === 'selling' && product.quantity > 0) { %>
                    <% if (!currentUser) { %>
                        <a href="/login" class="btn-secondary">Log in to Reserve</a>
                    <% } else if (currentUser.id === product.seller_id) { %>
                        <button class="btn-secondary" disabled>Your Product</button>
                    <% } else { %>
                        <a href="/reservations/add/<%= product.id %>" class="btn-secondary">Reserve Now</a>
                    <% } %>
                <% } else { %>
                    <button class="btn-secondary" disabled>Unavailable</button>
                <% } %>
                <a href="/details/<%= product.id %>/ratings" class="btn-outline">Give Rating</a>
                <% if (currentUser && currentUser.id !== product.seller_id) { %>
                    <a href="/user_report/<%= product.id %>" class="btn-report" title="Report this listing">&#9873;</a>
                <% } %>
            </div>
        </div>
    </div>

    <a href="/browse" class="btn-outline">&larr; Back to Browse</a>
</div>

<%- include('../partials/footer') %>

</body>
</html>
