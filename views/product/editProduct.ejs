<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Edit Listing - CampusCycle</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('../partials/navbar') %>

<section class="hero">
    <h1>Edit Listing</h1>
    <p>Update your listing's details below.</p>
</section>

<div class="admin-section">
    <div class="review-card form-card">
        <form action="/products/<%= product.id %>/edit" method="POST" enctype="multipart/form-data">

            <div style="margin-bottom:14px;">
                <label for="name">Product Name</label><br>
                <input type="text" id="name" name="name" class="reason-input" value="<%= product.name %>" required>
            </div>

            <div style="margin-bottom:14px;">
                <label for="categoryId">Category</label><br>
                <select id="categoryId" name="categoryId" class="ban-select" required>
                    <% categories.forEach(function(category) { %>
                        <option value="<%= category.id %>" <% if (product.category_id === category.id) { %>selected<% } %>><%= category.name %></option>
                    <% }); %>
                </select>
            </div>

            <div style="margin-bottom:14px;">
                <label for="description">Description</label><br>
                <textarea id="description" name="description" class="reason-input" rows="3" required><%= product.description %></textarea>
            </div>

            <div style="margin-bottom:14px;">
                <label for="price">Price ($)</label><br>
                <input type="number" id="price" name="price" class="reason-input" min="0" step="0.01" value="<%= product.price %>" required>
            </div>

            <div style="margin-bottom:14px;">
                <label for="condition">Condition</label><br>
                <select id="condition" name="condition" class="ban-select" required>
                    <option value="new" <% if (product.condition === 'new') { %>selected<% } %>>New</option>
                    <option value="like_new" <% if (product.condition === 'like_new') { %>selected<% } %>>Like New</option>
                    <option value="used" <% if (product.condition === 'used') { %>selected<% } %>>Used</option>
                    <option value="worn" <% if (product.condition === 'worn') { %>selected<% } %>>Worn</option>
                </select>
            </div>

            <div style="margin-bottom:14px;">
                <label for="quantity">Quantity</label><br>
                <input type="number" id="quantity" name="quantity" class="reason-input" min="1" value="<%= product.quantity %>" required>
            </div>

            <div style="margin-bottom:14px;">
                <label for="image">Image</label><br>
                <% if (product.image) { %>
                    <img src="/images/products/<%= product.image %>" alt="<%= product.name %>" style="width:80px; height:80px; object-fit:cover; border-radius:8px; margin-bottom:8px; display:block;">
                <% } %>
                <input type="file" id="image" name="image" accept="image/*">
                <p class="review-meta">Leave empty to keep the current image.</p>
            </div>

            <div style="margin-bottom:14px;">
                <label for="contactInfo">Contact / Collection Details</label><br>
                <input type="text" id="contactInfo" name="contactInfo" class="reason-input" value="<%= product.contact_info %>" required>
            </div>

            <button type="submit" class="btn-primary">Save Changes</button>
            <a href="/sales-history" class="btn-outline">Cancel</a>
        </form>
    </div>
</div>

<footer class="footer">
    &copy; 2026 <span class="brand-footer">CampusCycle</span> &mdash; Buy less. Reuse more.
</footer>

</body>
</html>
