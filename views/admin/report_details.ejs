<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Report #<%= report.id %> - CampusCycle Admin</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar">
    <div class="brand">
        <div class="brand-icon">&#9851;</div>
        <span class="campus">Campus</span><span class="cycle">Cycle</span>
    </div>

    <div class="nav-links">
        <a href="/admin">Dashboard</a>
        <a href="/admin/admin_report">Reports</a>
        <a href="/">Back to Home</a>
    </div>
</nav>

<section class="hero">
    <h1>Report #<%= report.id %></h1>
    <p>Category: <%= report.category.replace('_', ' ') %> &middot; Status: <%= report.status %></p>
</section>

<div class="admin-section">

    <!-- Report details -->
    <div class="review-card">
        <div class="review-thumb">&#9873;</div>
        <div class="review-body">
            <h4>Reported by <%= report.reporterName %></h4>
            <p class="review-meta"><%= report.reporterEmail %></p>
            <p style="margin-top:10px;"><%= report.description %></p>
            <p class="review-meta">Submitted: <%= new Date(report.created_at).toLocaleString() %></p>

            <% if (report.evidence_image) { %>
                <p class="review-meta">Evidence:</p>
                <img src="/images/<%= report.evidence_image %>" alt="evidence" style="max-width:260px; border-radius:8px; margin-top:6px;">
            <% } %>
        </div>
    </div>

    <!-- What/who was reported -->
    <% if (report.reported_product_id) { %>
        <div class="review-card">
            <div class="review-thumb">
                <img src="/images/<%= report.reportedProductImage %>" alt="<%= report.reportedProductName %>" style="width:100%; height:100%; object-fit:cover; border-radius:12px;">
            </div>
            <div class="review-body">
                <h4>Reported Listing: <%= report.reportedProductName %></h4>
                <p class="review-meta">Current status: <%= report.reportedProductStatus %></p>
                <a href="/products/<%= report.reported_product_id %>" class="btn-outline">View Listing</a>
            </div>
        </div>
    <% } %>

    <% if (report.reported_user_id) { %>
        <div class="review-card">
            <div class="review-thumb">&#128100;</div>
            <div class="review-body">
                <h4>Reported User: <%= report.reportedUserName %></h4>
                <p class="review-meta"><%= report.reportedUserEmail %></p>
                <p class="review-meta">Account status: <%= report.reportedUserBanned ? 'Banned' : 'Active' %></p>
            </div>
        </div>
    <% } %>

    <!-- Resolution -->
    <% if (report.status === 'pending') { %>
        <div class="review-card" style="display:block;">
            <h4 style="margin-bottom:12px;">Resolve this report</h4>

            <form action="/admin/admin_report/<%= report.id %>/approve" method="POST" style="margin-bottom:14px;">
                <input type="hidden" name="reportedProductId" value="<%= report.reported_product_id || '' %>">
                <input type="hidden" name="reportedUserId" value="<%= report.reported_user_id || '' %>">

                <div style="margin-bottom:10px;">
                    <label for="action">Action to take</label><br>
                    <select name="action" id="action" class="ban-select" required>
                        <option value="none">No action (record only)</option>
                        <% if (report.reported_product_id) { %>
                            <option value="remove_product">Remove the listing</option>
                        <% } %>
                        <% if (report.reported_user_id) { %>
                            <option value="ban_user">Ban the user</option>
                        <% } %>
                        <% if (report.reported_product_id && report.reported_user_id) { %>
                            <option value="ban_and_remove">Remove the listing AND ban the user</option>
                        <% } %>
                    </select>
                </div>

                <% if (report.reported_user_id) { %>
                    <div style="margin-bottom:10px;">
                        <label for="banDuration">Ban duration (only used if banning)</label><br>
                        <select name="banDuration" id="banDuration" class="ban-select">
                            <option value="1">1 day</option>
                            <option value="7">7 days</option>
                            <option value="30">30 days</option>
                            <option value="permanent">Permanent</option>
                        </select>
                    </div>
                <% } %>

                <div style="margin-bottom:10px;">
                    <label for="adminNote">Admin note</label><br>
                    <textarea name="adminNote" id="adminNote" class="reason-input" rows="2" placeholder="Reason recorded for this decision"></textarea>
                </div>

                <button type="submit" class="btn-primary">Approve Report</button>
            </form>

            <form action="/admin/admin_report/<%= report.id %>/dismiss" method="POST">
                <button type="submit" class="btn-outline">Dismiss Report</button>
            </form>
        </div>
    <% } else { %>
        <div class="review-card">
            <div class="review-body">
                <h4>Resolved</h4>
                <p class="review-meta">Decision: <%= report.status %></p>
                <p class="review-meta">Note: <%= report.admin_action %></p>
                <p class="review-meta">Resolved: <%= report.resolved_at ? new Date(report.resolved_at).toLocaleString() : '-' %></p>
            </div>
        </div>
    <% } %>

    <a href="/admin/admin_report" class="btn-outline">&larr; Back to Reports</a>
</div>

</body>
</html>
