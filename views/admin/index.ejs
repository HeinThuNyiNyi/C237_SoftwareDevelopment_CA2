<%- include('../partials/head', { title: 'Admin Dashboard' }) %>
<%- include('../partials/navbar') %>

<main class="container py-4">
  <%- include('../partials/messages') %>
  <%- include('../partials/back-button', { backUrl: '/' }) %>
  <h1 class="h2 mb-4">Admin Dashboard</h1>

  <div class="row g-3">
    <div class="col-md-4">
      <div class="card h-100 shadow-sm">
        <div class="card-body">
          <p class="text-muted mb-1">Pending products</p>
          <p class="display-5 fw-bold text-success"><%= counts.pending_products %></p>
          <a class="btn btn-outline-success" href="/admin/products">Review products</a>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card h-100 shadow-sm">
        <div class="card-body">
          <p class="text-muted mb-1">Pending reports</p>
          <p class="display-5 fw-bold text-danger"><%= counts.pending_reports %></p>
          <a class="btn btn-outline-danger" href="/admin/reports">Review reports</a>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card h-100 shadow-sm">
        <div class="card-body">
          <p class="text-muted mb-1">Registered users</p>
          <p class="display-5 fw-bold"><%= counts.users %></p>
          <a class="btn btn-outline-dark" href="/admin/users">Manage users</a>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
