<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CampusCycle Admin</title>
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<nav class="navbar">
    <a class="brand" href="/"><span class="brand-icon">&#9851;</span><span><span class="campus">Campus</span><span class="cycle">Cycle</span></span></a>
    <div class="nav-links"><a href="/admin">Dashboard</a><a href="/admin/users">Users</a><a href="/admin/reports">Reports</a><a href="/logout">Logout</a></div>
</nav>

<div class="stats-grid">
    <div class="stat-card"><div class="stat-value"><%= pendingProducts.length %></div><div class="stat-label">Pending Posts</div></div>
</div>

<main class="admin-section">
    <h2>Pending Product Posts</h2>
    <% if (!pendingProducts.length) { %><p class="empty-state">No pending posts right now.</p><% } %>
    <% pendingProducts.forEach((product) => { %>
        <article class="review-card">
            <div class="review-thumb"><% if (product.image) { %><img src="/images/<%= product.image %>" alt="<%= product.name %>"><% } %></div>
            <div class="review-body">
                <h4><%= product.name %></h4>
                <p class="review-meta">Seller: <%= product.sellerName %> &middot; Category: <%= product.categoryName %> &middot; $<%= Number(product.price).toFixed(2) %></p>
                <p class="review-meta">Submitted: <%= new Date(product.created_at).toLocaleDateString('en-SG') %></p>
            </div>
            <div class="review-actions">
                <form action="/admin/products/<%= product.id %>/approve" method="POST"><button type="submit" class="btn-primary">Approve Post</button></form>
                <form action="/admin/products/<%= product.id %>/reject" method="POST">
                    <input type="text" name="reason" class="reason-input" placeholder="Reason for rejection">
                    <button type="submit" class="btn-outline">Reject Post</button>
                </form>
            </div>
        </article>
    <% }) %>
</main>
</body>
</html>
