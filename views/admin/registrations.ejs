<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>New Registrations &mdash; CampusCycle Admin</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body class="admin-body">

<%- include('../partials/adminNavbar') %>

<div class="admin-layout">
    <%- include('../partials/adminSidebar') %>

    <div class="admin-main">
    <div class="admin-section">

    <h2>New Registrations
        <% if (pendingCount > 0) { %>
            <span class="reg-count-badge"><%= pendingCount %> waiting</span>
        <% } %>
    </h2>

    <% if (errors && errors.length > 0) { %>
        <div class="auth-alert auth-alert-error">
            <% errors.forEach(function(message) { %><p><%= message %></p><% }); %>
        </div>
    <% } %>

    <% if (success && success.length > 0) { %>
        <div class="auth-alert auth-alert-success">
            <% success.forEach(function(message) { %><p><%= message %></p><% }); %>
        </div>
    <% } %>

    <% if (registrations.length === 0) { %>
        <p>No registrations are waiting for approval.</p>
    <% } %>

    <% registrations.forEach(function(registration) { %>
        <div class="review-card">

            <div class="review-body">
                <div class="reg-head">
                    <h4><%= registration.name %></h4>
                    <span class="reg-status reg-status-pending">waiting</span>
                </div>

                <p class="review-meta">
                    <%= registration.email %>
                    <% if (registration.phone) { %> &middot; <%= registration.phone %><% } %>
                </p>
                <p class="review-meta">
                    Registered <%= new Date(registration.created_at).toLocaleDateString('en-GB', { day:'numeric', month:'short', year:'numeric' }) %>
                </p>
            </div>

            <div class="review-actions reg-actions">

                <!-- UPDATE: sets is_approved = 1 so the student can log in -->
                <form action="/admin/registrations/<%= registration.id %>/approve" method="POST"
                      onsubmit="return confirm('Approve <%= registration.name %>? They will be able to log in immediately.');">
                    <button type="submit" class="btn-primary">Approve Account</button>
                </form>

                <!-- DELETE: removes the unapproved row -->
                <form action="/admin/registrations/<%= registration.id %>/reject" method="POST"
                      onsubmit="return confirm('Reject and delete this registration? This cannot be undone.');">
                    <button type="submit" class="btn-outline">Reject</button>
                </form>

            </div>
        </div>
    <% }); %>

    </div>
    </div>
</div>

</body>
</html>
