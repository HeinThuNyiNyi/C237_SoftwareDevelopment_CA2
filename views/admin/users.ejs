<%- include('../partials/head', { title: 'User Management' }) %>
<%- include('../partials/navbar') %>

<main class="container py-4">
  <%- include('../partials/messages') %>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h1 class="h2 mb-1">User Management</h1>
      <p class="text-muted mb-0">Ban or restore student accounts.</p>
    </div>
    <a class="btn btn-outline-secondary" href="/admin">Dashboard</a>
  </div>

  <div class="table-responsive bg-white border rounded shadow-sm">
    <table class="table align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Role</th>
          <th>Status</th>
          <th>Ban reason</th>
          <th class="text-end">Action</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(function(account) { %>
          <tr>
            <td><a href="/users/<%= account.id %>"><%= account.name %></a></td>
            <td><%= account.email %></td>
            <td>user</td>
            <td>
              <span class="badge text-bg-<%= account.is_banned ? 'danger' : 'success' %>">
                <%= account.is_banned ? 'Banned' : 'Active' %>
              </span>
            </td>
            <td><%= account.ban_reason || '—' %></td>
            <td class="text-end">
              <% if (account.is_banned) { %>
                <form method="POST" action="/admin/users/<%= account.id %>/unban">
                  <button class="btn btn-sm btn-success" type="submit">Unban</button>
                </form>
              <% } else { %>
                <button class="btn btn-sm btn-outline-danger" type="button" data-bs-toggle="modal" data-bs-target="#banUser<%= account.id %>">Ban</button>
              <% } %>
            </td>
          </tr>

        <% }) %>
      </tbody>
    </table>
  </div>
  <% users.forEach(function(account) { %>
    <% if (!account.is_banned) { %>
      <div class="modal fade" id="banUser<%= account.id %>" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
          <div class="modal-content">
            <form method="POST" action="/admin/users/<%= account.id %>/ban">
              <div class="modal-header">
                <h2 class="modal-title fs-5">Ban <%= account.name %></h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <div class="modal-body">
                <label class="form-label" for="banReason<%= account.id %>">Reason</label>
                <textarea class="form-control" id="banReason<%= account.id %>" name="reason" rows="3" required></textarea>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-danger" type="submit">Ban User</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    <% } %>
  <% }) %>
</main>

<%- include('../partials/footer') %>
