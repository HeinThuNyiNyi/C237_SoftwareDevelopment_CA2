<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reports - CampusCycle Admin</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar">
    <div class="brand">
        <div class="brand-icon">&#9851;</div>
        <span class="campus">Campus</span><span class="cycle">Cycle</span>
    </div>

    <div class="nav-links">
        <a href="/admin">Dashboard</a>

        <div class="dropdown">
            <a href="/admin/products">Products</a>
            <div class="dropdown-menu">
                <a href="/admin/products?status=pending">Pending</a>
                <a href="/admin/products?status=selling">Approved</a>
                <a href="/admin/products?status=rejected">Rejected</a>
            </div>
        </div>

        <a href="/admin/users">Users</a>
        <a href="/admin/reports">Reports</a>
        <a href="/admin/reservations">Reservations</a>
        <a href="/logout">Logout</a>
    </div>
</nav>

<section class="hero">
    <h1>Reported Products &amp; Users</h1>
    <p>Review reports submitted by buyers and sellers, then approve or dismiss them.</p>
</section>

<!-- Status filter tabs -->
<div class="admin-section" style="padding-top:0; display:flex; gap:8px;">
    <a href="/admin/admin_report?status=pending" class="<%= selectedStatus === 'pending' ? 'btn-primary' : 'btn-outline' %>">Pending</a>
    <a href="/admin/admin_report?status=approved" class="<%= selectedStatus === 'approved' ? 'btn-primary' : 'btn-outline' %>">Approved</a>
    <a href="/admin/admin_report?status=rejected" class="<%= selectedStatus === 'rejected' ? 'btn-primary' : 'btn-outline' %>">Dismissed</a>
    <a href="/admin/admin_report?status=all" class="<%= selectedStatus === 'all' ? 'btn-primary' : 'btn-outline' %>">All</a>
</div>

<div class="admin-section">
    <h2>Reports</h2>

    <% if (reports.length === 0) { %>
        <p>No reports found for this filter.</p>
    <% } %>

    <% reports.forEach(function(report) { %>
        <div class="review-card">
            <div class="review-thumb">&#9873;</div>
            <div class="review-body">
                <h4>
                    <% if (report.reportedProductName) { %>
                        Listing: <%= report.reportedProductName %>
                    <% } %>
                    <% if (report.reportedUserName) { %>
                        <% if (report.reportedProductName) { %> &middot; <% } %>
                        User: <%= report.reportedUserName %>
                    <% } %>
                </h4>
                <p class="review-meta">Reported by: <%= report.reporterName %> &middot; Category: <%= report.category.replace('_', ' ') %></p>
                <p class="review-meta">"<%= report.description %>"</p>
                <p class="review-meta">Submitted: <%= new Date(report.created_at).toLocaleDateString() %></p>
                <span class="status-badge status-<%= report.status %>" style="position:static; display:inline-block; margin-top:4px;"><%= report.status %></span>
            </div>
            <div class="review-actions">
                <a href="/admin/admin_report/<%= report.id %>" class="btn-primary">Review Report</a>
            </div>
        </div>
    <% }); %>
</div>

<!-- Currently banned users -->
<div class="admin-section">
    <h2>Banned Users</h2>

    <% if (bannedUsers.length === 0) { %>
        <p>No users are currently banned.</p>
    <% } %>

    <% bannedUsers.forEach(function(user) { %>
        <div class="user-row">
            <div>
                <div class="user-name"><%= user.name %></div>
                <div class="user-email">
                    <%= user.email %> &middot;
                    <% if (user.banned_until) { %>
                        Banned until <%= new Date(user.banned_until).toLocaleDateString() %>
                    <% } else { %>
                        Banned permanently
                    <% } %>
                    <% if (user.ban_reason) { %> &middot; Reason: <%= user.ban_reason %> <% } %>
                </div>
            </div>
            <div class="user-actions">
                <form action="/admin/users/<%= user.id %>/unban" method="POST">
                    <button type="submit" class="btn-secondary">Cancel Ban</button>
                </form>
            </div>
        </div>
    <% }); %>
</div>

</body>
</html>
