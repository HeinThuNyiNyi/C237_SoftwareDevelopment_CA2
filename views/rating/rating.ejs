<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= pageTitle %> - CampusCycle</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('../partials/navbar') %>

<section class="hero">
    <h1><%= pageTitle %></h1>
    <p>Rate <%= item.name %> and share your experience with other students.</p>
</section>

<div class="admin-section">
    <div class="review-card form-card">

        <% if (error) { %>
            <p style="color:#b83b3b;"><%= error %></p>
        <% } %>

        <form action="/details/<%= itemId %>/rating/new" method="POST" enctype="multipart/form-data">

            <div style="margin-bottom:14px;">
                <label>Your Rating</label><br>
                <div class="star-picker" id="star-picker">
                    <% for (let value = 1; value <= 5; value++) { %>
                        <input
                            type="radio"
                            name="rating"
                            id="rating-<%= value %>"
                            value="<%= value %>"
                            <%= selectedRating === value ? 'checked' : '' %>
                            required
                        >
                        <label class="star-button <%= value <= selectedRating ? 'is-filled' : '' %>" for="rating-<%= value %>" data-rating="<%= value %>">&#9733;</label>
                    <% } %>
                </div>
            </div>

            <div style="margin-bottom:14px;">
                <label for="comment">Your Experience</label><br>
                <textarea id="comment" name="comment" class="reason-input" maxlength="500" rows="5" placeholder="Describe the item's condition and your experience with the seller."><%= comment %></textarea>
                <p class="review-meta" id="comment-count">0 / 500</p>
            </div>

            <div style="margin-bottom:14px;">
                <label for="image">Photo (optional)</label><br>
                <% if (existingImage) { %>
                    <img src="<%= existingImage %>" alt="Current photo" style="width:120px; height:120px; object-fit:cover; border-radius:12px; margin:8px 0; display:block;">
                    <p class="review-meta">Uploading a new photo replaces this one.</p>
                <% } %>
                <input type="file" id="image" name="image" accept="image/*">
            </div>

            <div style="margin-bottom:14px;">
                <label>
                    <input type="checkbox" name="isAnonymous" value="1" <%= isAnonymous ? 'checked' : '' %>>
                    Post anonymously (your name is hidden from other students)
                </label>
            </div>

            <button type="submit" class="btn-primary">
                <%= selectedRating ? 'Update Review' : 'Submit Review' %>
            </button>
        </form>
    </div>
</div>

<footer class="footer">
    &copy; 2026 <span class="brand-footer">CampusCycle</span> &mdash; Buy less. Reuse more.
</footer>

<script src="/js/rating.js" defer></script>
</body>
</html>
