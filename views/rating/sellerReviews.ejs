<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reviews for <%= seller.name %> - CampusCycle</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('../partials/navbar') %>

<section class="hero">
    <h1>Reviews for <%= seller.name %></h1>
    <p><%= reviews.length %> review<%= reviews.length === 1 ? '' : 's' %> from verified buyers.</p>
</section>

<div class="admin-section">

    <a href="/users/<%= seller.id %>" class="btn-outline pubprof-link-btn" style="margin-bottom:16px;">&larr; Back to profile</a>

    <% if (reviews.length === 0) { %>
        <p>No reviews yet.</p>
    <% } %>

    <% reviews.forEach(function(review) { %>
        <div class="pubprof-review">
            <div class="pubprof-review-head">
                <strong><%= review.authorLabel %></strong>
                <span class="pubprof-review-product">
                    on <%= review.productName %> &middot; <%= new Date(review.updatedAt).toLocaleDateString() %>
                </span>
            </div>
            <div class="pubprof-review-stars">
                <% for (let star = 1; star <= 5; star++) { %>
                    <%= star <= review.rating ? '★' : '☆' %>
                <% } %>
            </div>
            <% if (review.comment) { %>
                <p class="pubprof-review-comment"><%= review.comment %></p>
            <% } %>
        </div>
    <% }); %>

</div>

<footer class="footer">
    &copy; 2026 <span class="brand-footer">CampusCycle</span> &mdash; Buy less. Reuse more.
</footer>

</body>
</html>
