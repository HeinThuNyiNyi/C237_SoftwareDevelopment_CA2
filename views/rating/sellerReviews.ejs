<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reviews for <%= seller.name %> - CampusCycle</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('../partials/navbar') %>

<section class="hero">
    <h1>Reviews for <%= seller.name %></h1>
    <p><%= reviews.length %> review<%= reviews.length === 1 ? '' : 's' %> from verified buyers.</p>
</section>

<div class="admin-section">

    <a href="/users/<%= seller.id %>" class="btn-outline pubprof-link-btn review-back-link">&larr; Back to profile</a>

    <% if (reviews.length === 0) { %>
        <p>No reviews yet.</p>
    <% } %>

    <% reviews.forEach(function(review) { %>
        <%- include('../partials/reviewCard', {
            review,
            compact: true,
            showImage: false,
            showProduct: true,
            showDate: true,
            emptyCommentText: null
        }) %>
    <% }); %>

</div>

<%- include('../partials/footer') %>

</body>
</html>
