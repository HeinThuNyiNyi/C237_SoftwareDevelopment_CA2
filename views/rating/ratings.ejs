<%
  const averageRating = Number(ratingSummary.averageRating || 0);
  const reviewCount = Number(ratingSummary.reviewCount || 0);
  const roundedAverage = Math.round(averageRating);
%>
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reviews for <%= item.name %> - CampusCycle</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('../partials/navbar') %>

<section class="hero">
    <h1>Reviews for <%= item.name %></h1>
    <%- include('../partials/stars', {
        value: roundedAverage,
        containerClass: 'stars-display rating-overview-stars',
        label: `${averageRating.toFixed(1)} out of 5 stars`
    }) %>
    <p><%= averageRating.toFixed(1) %> out of 5 &middot; <%= reviewCount %> review<%= reviewCount === 1 ? '' : 's' %></p>
</section>

<div class="admin-section">

    <%- include('../partials/flashMessages', {
        successMessages: success,
        errorMessages: error
    }) %>

    <% if (canReview) { %>
        <a href="/details/<%= itemId %>/ratings/new" class="btn-primary rating-write-link">
            <%= hasExistingReview ? 'Edit My Review' : 'Write a Review' %>
        </a>
    <% } else if (!isLoggedIn) { %>
        <p>Sign in with the account used for the purchase to write a review.</p>
    <% } else { %>
        <p>Only buyers who purchased this item can write a review.</p>
    <% } %>

    <% if (reviews.length === 0) { %>
        <p>No reviews yet.</p>
    <% } %>

    <% reviews.forEach(function(review) { %>
        <%- include('../partials/reviewCard', {
            review,
            compact: false,
            showImage: true,
            showProduct: false,
            showDate: true,
            emptyCommentText: 'This buyer left a star rating without a written comment.'
        }) %>
    <% }); %>

</div>

<%- include('../partials/footer') %>

</body>
</html>
